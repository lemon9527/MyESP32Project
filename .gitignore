# macOS 系统文件
.DS_Store
**/.DS_Store

# ESP-IDF 编译产物
build/
**/build/

# ESP-IDF sdkconfig 生成文件（保留 sdkconfig.defaults 作为配置模板）
sdkconfig
sdkconfig.old
sdkconfig.ci
**/sdkconfig
**/sdkconfig.old
**/sdkconfig.ci

# 依赖锁文件（可由 idf.py 重新生成）
dependencies.lock
**/dependencies.lock

# IDF 组件管理器下载的组件
managed_components/
**/managed_components/

# Python 编译缓存
__pycache__/
**/__pycache__/
*.pyc
*.pyo

# 编译数据库（可选，体积较大）
compile_commands.json
**/compile_commands.json

# IDE 配置（VSCode 等）
.vscode/
.idea/
*.swp
*.swo
*~